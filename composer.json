{
    "name": "maxarafat/vendor-marketplace",
    "description": "Multi-vendor marketplace plugin for WooCommerce",
    "type": "wordpress-plugin",
    "license": "GPL-2.0+",
    "authors": [
        {
            "name": "Max Arafat",
            "email": "max@example.com"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "squizlabs/php_codesniffer": "^3.6",
        "wp-coding-standards/wpcs": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "VMP\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VMP\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs --standard=WordPress app/ admin/ public/",
        "phpcbf": "phpcbf --standard=WordPress app/ admin/ public/"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
